[Unit]
Description=PAL Distributor Telegram Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/telegram-bot/pal-distributor-bot
ExecStart=/opt/telegram-bot/pal-distributor-bot/venv/bin/python bot.py
Restart=on-failure
RestartSec=10
EnvironmentFile=/opt/telegram-bot/pal-distributor-bot/.env

[Install]
WantedBy=multi-user.target
